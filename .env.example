# ============================================
# Client-side (Vite)
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ============================================
# Server-side (Vercel Cron & API Routes)
# ============================================
# Get SUPABASE_SERVICE_ROLE_KEY from Supabase dashboard:
# Settings > API > Service Role Secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# (Optional) Email notifications via SendGrid
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxx...
EMAIL_FROM=no-reply@tu-dominio.com

# (Optional) Cron job threshold for "por vencer" alerts (days, default: 4)
POR_VENCER_DAYS=4
